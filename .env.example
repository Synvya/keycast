# Keycast Environment Variables
# Copy this file to .env and fill in your values

# Domain for production deployment (required for docker-compose)
DOMAIN=keycast.example.com

# PostgreSQL database password (required for docker-compose)
POSTGRES_PASSWORD=change-this-secure-password-for-nonlocal

# Database connection URL
# Local dev: postgres://postgres:password@localhost/keycast
# Docker: postgres://postgres:${POSTGRES_PASSWORD}@postgres/keycast
DATABASE_URL=postgres://postgres:change-this-secure-password-for-nonlocal@localhost/keycast

# Allowed public keys for admin access (comma-separated)
# Leave empty to allow any authenticated user
ALLOWED_PUBKEYS=

# Master encryption key path (generated via bun run key:generate)
MASTER_KEY_PATH=./master.key

# Use Google Cloud KMS instead of local file-based encryption
USE_GCP_KMS=false

# Google Cloud KMS configuration (only if USE_GCP_KMS=true)
GCP_PROJECT_ID=your-project-id
GCP_KMS_LOCATION=global
GCP_KMS_KEY_RING=keycast-keys
GCP_KMS_KEY_NAME=master-key

# Allowed CORS origins for restricted /auth endpoints (comma-separated).
# Wildcards are supported for subdomains, for example Cloudflare Pages previews.
ALLOWED_ORIGINS=https://keycast.example.com,https://peek.verse.app,https://*.openvine-app.pages.dev

# Bunker relay infrastructure (comma-separated WebSocket URLs) - REQUIRED
# No default - must be explicitly set to prevent unintended external connections
# The signer connects to these relays for NIP-46 communication
# All bunker URLs will reference these relays (deployment-wide setting)
# BUNKER_RELAYS=wss://relay.divine.video,wss://relay.primal.net,wss://relay.nsec.app,wss://nos.lol

# Local dev — points at the relay started by `make stack-up` (port 7777).
# Swap for the staging/production values below when needed.
#   Staging: wss://relay.staging.synvya.com
#   Production: wss://relay.damus.io,wss://nos.lol,wss://relay.synvya.com
# BUNKER_RELAYS=ws://localhost:7777
# use host.docker.internal for the docker environments
BUNKER_RELAYS=ws://localhost:7777,ws://host.docker.internal:7777
VITE_NDK_EXPLICIT_RELAYS=ws://localhost:7777
VITE_NDK_BUNKER_RELAYS=ws://localhost:7777

# Optional: SendGrid API key for email sending (if not set, emails will be logged to console)
SENDGRID_API_KEY=

# Optional: From email address for email notifications
FROM_EMAIL=noreply@keycast.example.com

# Optional: From name for email notifications
FROM_NAME=Synvya

# Optional: Base URL for email verification links (used in email templates)
# Should match your frontend URL
BASE_URL=http://localhost:5173

# Optional: Disable email sending (set to any value to disable)
# Useful for testing or load testing scenarios
# DISABLE_EMAILS=

# Rust logging level
RUST_LOG=info,keycast_signer=debug

# Enable /examples directory (development only, set to false in production)
ENABLE_EXAMPLES=false

# Show teams functionality in the frontend (default: hidden)
# Set to "true" to enable team management UI
SHOW_TEAMS_FUNCTIONALITY=false

# Server Nostr secret key for signing UCANs (hex format, 64 chars)
# Generate with: openssl rand -hex 32
# IMPORTANT: Keep this secret secure - used to sign session tokens for users without keys
SERVER_NSEC=


# Redis connection URL (required for cluster coordination and support admin management)
# Local dev: redis://localhost:16379 (non-standard port to avoid accidental production connections)
# Docker: redis://redis:6379
REDIS_URL=redis://redis:6379

# Frontend runtime configuration (injected into HTML at runtime)
# These are used by the SvelteKit frontend, not build-time variables

# Frontend domain/API base URL (used for API calls and NIP-05 discovery)
VITE_DOMAIN=http://localhost:3000

# Allowed public keys for admin access in frontend (comma-separated)
# Should match ALLOWED_PUBKEYS for consistency
VITE_ALLOWED_PUBKEYS=


# NDK explicit relay URLs — already set above for local dev (ws://localhost:7777).
# Public-relay fallback shown here as a reference; commented out so the local
# default at the top of this file takes effect. In env files the LAST assignment
# wins, so leaving these uncommented would silently override the local values.
# VITE_NDK_EXPLICIT_RELAYS=wss://relay.divine.video,wss://purplepag.es,wss://relay.nostr.band,wss://relay.snort.social,wss://relay.primal.net
#  ... use wss://relay.local.synvya.com if we want to stay consistent with other env settings (ToDo: deprecate this relay)
# NDK bunker relay URLs — already set above for local dev (ws://localhost:7777).
# Public-relay fallback shown here as a reference; commented out (see note above).
# VITE_NDK_BUNKER_RELAYS=wss://relay.divine.video,wss://relay.primal.net,wss://relay.nsec.app,wss://nos.lol
